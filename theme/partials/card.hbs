{{!-- Card partial for modern DanjuTech design --}}
<article class="glass border border-white/10 rounded-3xl p-8 card-hover group">
    <div class="flex items-center gap-3 mb-6">
        <div class="w-8 h-8 bg-cyan-400/10 rounded-2xl flex items-center justify-center text-cyan-400 text-sm font-mono">AI</div>
        <div class="text-xs uppercase tracking-widest text-cyan-400 font-medium">{{tags}}</div>
    </div>
    
    <h3 class="text-2xl font-semibold text-white mb-3 leading-tight group-hover:text-cyan-400 transition-colors">
        <a href="{{url}}">{{title}}</a>
    </h3>
    
    <p class="text-zinc-400 line-clamp-3 mb-8">
        {{excerpt}}
    </p>
    
    <div class="flex items-center justify-between text-sm">
        <div class="flex items-center gap-2 text-zinc-500">
            <time datetime="{{date format='YYYY-MM-DD'}}">{{date format="DD MMM YYYY"}}</time>
        </div>
        <a href="{{url}}" class="text-cyan-400 hover:text-white flex items-center gap-1 text-sm font-medium">
            Read more →
        </a>
    </div>
</article>